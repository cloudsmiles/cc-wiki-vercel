{
  "outputDirectory": "wiki",
  "rewrites": [
    { "source": "/static/:match", "destination": "/static/:match" },
    { "source": "/favicon.ico", "destination": "/favicon.ico" },
    { "source": "/index.xml", "destination": "/index.xml" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/:path*/index", "destination": "/:path*/index.html" },
    { "source": "/:path*", "destination": "/:path*.html" }
  ]
}